KALSHI_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY=your_api_key_here
KALSHI_RSA_KEY_PATH=/absolute/path/to/kalshi-private-key.pem
# Optional alternative to path:
# KALSHI_RSA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
NWS_USER_AGENT=kalshi-weather-model/1.0 (contact: you@example.com)
ALLOW_LIVE_TRADING=0
LIVE_AUTO_ENABLE_ON_CHAMPION=1
LIVE_STARTING_EQUITY=50
LIVE_EQUITY_SYNC_ENABLED=1
LIVE_MAX_NOTIONAL_UTILIZATION=0.60

# Strategy quality warmup
STRATEGY_PARSE_ALERT_MIN_RAW=25
